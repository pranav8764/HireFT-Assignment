# MongoDB Configuration
# MongoDB connection string for database access
# Example: mongodb://localhost:27017/job-match-analyzer
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/job-match-analyzer
MONGODB_URI=mongodb://localhost:27017/job-match-analyzer

# OpenAI API Configuration
# API key for OpenAI GPT-4 access (required for AI suggestions)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
# Port number for the Express server (default: 5000)
PORT=5000

# CORS Configuration (optional)
# Frontend URL for CORS policy (default: http://localhost:5173)
FRONTEND_URL=http://localhost:5173
